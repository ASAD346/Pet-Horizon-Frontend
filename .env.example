# Pet Horizon API base URL (no trailing slash)
# Used by constants/api.ts → API_BASE_URL
#
# Production (Render):
#   EXPO_PUBLIC_API_URL=https://pet-horizon-backend.onrender.com/v1
#
# Local dev — pick one (copy this file to `.env` and restart Expo):
#   Physical phone (Expo Go):  http://YOUR_PC_IP:3000/v1  ← use IP from Metro (exp://192.168.x.x:8081)
#   Android emulator:          http://10.0.2.2:3000/v1
#   iOS simulator / web:       http://localhost:3000/v1
#
# Endpoint paths live in: constants/api.ts → API_ENDPOINTS
EXPO_PUBLIC_API_URL=https://pet-horizon-backend.onrender.com/v1
